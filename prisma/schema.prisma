generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Auth.js — https://authjs.dev/getting-started/adapters/prisma

enum AccessStatus {
  PENDING
  ACTIVE
}

model User {
  id            String              @id @default(cuid())
  name          String?
  email         String?             @unique
  emailVerified DateTime?
  image         String?
  /// New signups are PENDING until an operator sets ACTIVE in the database.
  accessStatus  AccessStatus        @default(PENDING)
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  attachments   ProjectAttachment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  ownerId             String
  /// When null or unknown, app uses default gpt-4o-mini (see OPENAI_CHAT_MODEL_OPTIONS in code).
  openaiChatModel     String?
  bitrixProjectId     String?
  taskOwnerId         String?
  taskAssigneeId      String?
  /// When true, real (non–dry-run) Bitrix sync is blocked until the user clears the checkbox in the Bitrix panel.
  bitrixSyncCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  /// Last time the user was active in Main (no phase); drives sidebar order vs phases.
  mainLastUsedAt      DateTime @default(now())

  owner         User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  phases        Phase[]
  messages      Message[]
  planSnapshots PlanSnapshot[]
  attachments   ProjectAttachment[]

  @@index([ownerId])
  @@index([ownerId, updatedAt])
}

model Phase {
  id         String   @id @default(cuid())
  projectId  String
  label      String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  /// Last activity in this phase (messages, navigation, or creation); drives sidebar order.
  lastUsedAt DateTime @default(now())

  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages      Message[]
  planSnapshots PlanSnapshot[]
  attachments   ProjectAttachment[]

  @@index([projectId])
  @@index([projectId, sortOrder])
  @@index([projectId, lastUsedAt])
}

enum MessageRole {
  user
  assistant
}

model Message {
  id        String      @id @default(cuid())
  projectId String
  phaseId   String?
  role      MessageRole
  content   String      @db.Text
  createdAt DateTime    @default(now())

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase       Phase?              @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  attachments ProjectAttachment[]

  @@index([projectId, createdAt])
  @@index([phaseId])
  @@index([projectId, phaseId, createdAt])
}

model PlanSnapshot {
  id        String   @id @default(cuid())
  projectId String
  phaseId   String?
  payload   Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase   Phase?  @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([phaseId])
  @@index([projectId, phaseId, updatedAt])
}

enum AttachmentFormat {
  md
  txt
  json
  yaml
}

model ProjectAttachment {
  id           String           @id @default(cuid())
  projectId    String
  phaseId      String?
  /// Linked once the message that references this attachment is persisted; null while in-flight.
  messageId    String?
  uploadedById String
  filename     String
  format       AttachmentFormat
  sizeBytes    Int
  /// Stable object key in R2; unique to enable safe re-uploads and idempotent deletes.
  r2Key        String           @unique
  /// SHA-256 of the original bytes; useful for de-duplication and integrity checks.
  sha256       String
  createdAt    DateTime         @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase    Phase?   @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  uploader User     @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([projectId, createdAt])
  @@index([messageId])
  @@index([projectId, format])
}
