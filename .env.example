# Copy to .env and fill in. Do not commit .env.

# Numeric ID of the workgroup / project / Scrum group in Bitrix24 (GROUP_ID / groupId for API calls).
Bitrix24_Project_id=

# Incoming webhook base URL with trailing slash:
# https://<portal>.bitrix24.<tld>/rest/<user_id>/<secret>/
Webhook_URL=

# Optional legacy fallback: if Task_owner_id / Task_Assignee_id are omitted, both fall back to this ID (then to 1).
# Bitrix24_responsible_id=

# Task_owner_id → CREATED_BY (постановщик, от чьего имени создаётся задача).
# Task_Assignee_id → RESPONSIBLE_ID (исполнитель). YAML `responsible_id` overrides assignee only.
Task_owner_id=
Task_Assignee_id=

