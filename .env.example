# Copy to `.env` locally. Do not commit `.env`.
# Stack and variables: `docs/TECH_CARD.md`

# ——— Application (Next.js / Vercel) ———
NODE_ENV="development"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# ——— Database (Neon PostgreSQL) ———
DATABASE_URL=""
# Optional tuning — align with team / Neon pooler docs
DATABASE_CONNECTION_LIMIT="10"
DATABASE_POOL_TIMEOUT="20"

# ——— Auth.js (see `docs/TECH_CARD.md` §5) ———
AUTH_SECRET=""
# Canonical URL of the app (required in production), e.g. https://planrelay.example.com
AUTH_URL="http://localhost:3000"
# Trust host header on Vercel
AUTH_TRUST_HOST="true"

# ——— Email (magic link; Resend) ———
# Auth.js Email provider requires a dummy SMTP `server` in code; real delivery uses Resend when RESEND_API_KEY is set.
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@example.com"

# ——— Cache ——— (optional; not required for PlanRelay v1)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ——— File storage ——— (optional; not required for PlanRelay v1)
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_URL=""

# ——— Bitrix24 (CLI `npm run sync` + server-side sync) ———
# Per-project overrides for IDs may be stored in DB in the web app; env remains fallback for CLI.

# Numeric ID of the workgroup / project / Scrum group in Bitrix24 (GROUP_ID / groupId for API calls).
Bitrix24_Project_id=

# Incoming webhook base URL with trailing slash:
# https://<portal>.bitrix24.<tld>/rest/<user_id>/<secret>/
Webhook_URL=

# Optional legacy fallback: if Task_owner_id / Task_Assignee_id are omitted, both fall back to this ID (then to 1).
# Bitrix24_responsible_id=

# Task_owner_id → CREATED_BY (постановщик, от чьего имени создаётся задача).
# Task_Assignee_id → RESPONSIBLE_ID (исполнитель). YAML `responsible_id` overrides assignee only.
Task_owner_id=
Task_Assignee_id=

# ——— OpenAI (server-side only; never expose to client) ———
OpenAI_API_Key=
