# Copy to `.env` locally. Do not commit `.env`.
# Stack and variables: `docs/TECH_CARD.md`
#
# --- Production (Vercel / hosting) — manual checklist ---
# - Set the same variables in the host dashboard (Production + Preview as needed).
# - DATABASE_URL: Neon pooler URL for the app user (least privilege, not superuser).
# - AUTH_SECRET, AUTH_URL (canonical https URL), UPSTASH_REDIS_* (required: rate limits fail closed in NODE_ENV=production).
# - Optional hardening: Cloudflare (or similar) — HTTPS, HSTS, WAF, rate limits; Neon — backups and restore drill.

# ——— Application (Next.js / Vercel) ———
NODE_ENV="development"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# ——— Database (Neon PostgreSQL) ———
DATABASE_URL=""
# Optional tuning — align with team / Neon pooler docs
DATABASE_CONNECTION_LIMIT="10"
DATABASE_POOL_TIMEOUT="20"

# ——— Auth.js (see `docs/TECH_CARD.md` §5) ———
AUTH_SECRET=""
# Canonical URL of the app (required in production), e.g. https://planrelay.example.com
AUTH_URL="http://localhost:3000"
# Trust host header on Vercel
AUTH_TRUST_HOST="true"

# ——— Email (magic link; Resend) ———
# Auth.js Email provider requires a dummy SMTP `server` in code; real delivery uses Resend when RESEND_API_KEY is set.
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@example.com"

# ——— Rate limiting (Upstash) ———
# Required in production (NODE_ENV=production): chat and Bitrix sync call enforceRateLimit().
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ——— File storage (Cloudflare R2) ———
# Required for project chat attachments (.md/.txt/.json/.yaml uploads).
# Endpoint is derived as https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com.
# Use a dedicated bucket per environment (dev/staging/prod) and keys with least privilege.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Optional public CDN base URL; not used by current upload flow (server-side reads only).
R2_PUBLIC_URL=""

# ——— Bitrix24 (server-side sync from the web app) ———
# Incoming webhook base URL with trailing slash:
# https://<portal>.bitrix24.<tld>/rest/<user_id>/<secret>/
# Project/group id, task creator, and default assignee are set per project in the app (not in .env).
Webhook_URL=

# ——— OpenAI (server-side only; never expose to client) ———
OpenAI_API_Key=
